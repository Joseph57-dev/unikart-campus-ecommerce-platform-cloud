# Environment Configuration for Unikart Backend
# Copy this file to .env and fill in your values

# Server Configuration
PORT=80
NODE_ENV=production

# Database (PostgreSQL RDS)
DATABASE_URL=postgresql://adminuser:StrongPass123!@unikart-postgres.chogwkgeox2f.eu-north-1.rds.amazonaws.com:5432/postgres

# AWS Configuration
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Cognito Configuration
COGNITO_REGION=eu-north-1
COGNITO_USER_POOL_ID=eu-north-1_Jpd1eE1wJ
COGNITO_APP_CLIENT_ID=48ip13sdqqc03pfr8gfoh769ji
COGNITO_IDENTITY_POOL_ID=your_identity_pool_id

# SNS Configuration (for notifications)
AWS_SNS_TOPIC_ARN=arn:aws:sns:eu-north-1:584164024115:order-notifications

# SES Configuration (for emails)
AWS_SES_SENDER_EMAIL=noreply@yourdomain.com
AWS_SES_CONFIGURATION_SET=your_config_set

# API Keys
API_SECRET_KEY=your_api_secret
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=7d

# URLs
FRONTEND_URL=http://unikart-alb-296069847.eu-north-1.elb.amazonaws.com
BACKEND_URL=http://unikart-alb-296069847.eu-north-1.elb.amazonaws.com
API_BASE_URL=http://unikart-alb-296069847.eu-north-1.elb.amazonaws.com

# S3 Configuration
AWS_S3_BUCKET=unikart-products
AWS_S3_REGION=eu-north-1
