# Shared environment variables for Unikart deployment
# Copy this file to .env in the backend directory or to process environment values.

# Server
PORT=80
NODE_ENV=production

# PostgreSQL RDS
DB_HOST=unikart-postgres.chogwkgeox2f.eu-north-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=adminuser
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://adminuser:your_db_password@unikart-postgres.chogwkgeox2f.eu-north-1.rds.amazonaws.com:5432/postgres

# AWS
AWS_REGION=eu-north-1
AWS_SNS_TOPIC_ARN=arn:aws:sns:eu-north-1:584164024115:unikart-notifications

# API JWT (required for /api/auth/* and protected routes)
JWT_SECRET=unikart_super_secure_key_123
JWT_EXPIRE=7d

# Frontend
FRONTEND_URL=http://unikart-alb-296069847.eu-north-1.elb.amazonaws.com
API_BASE_URL=http://unikart-alb-296069847.eu-north-1.elb.amazonaws.com/api
